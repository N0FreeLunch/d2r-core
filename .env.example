# D2R-Core Environment Configuration Example
# Copy this file to .env and adjust the paths to your local environment.

# 1. Repository Paths (Absolute paths recommended)
D2R_CORE_PATH=C:\Users\<USER>\dev\d2r\d2r-core
D2R_SPEC_PATH=C:\Users\<USER>\dev\d2r\d2r-core\d2r-spec
D2R_DATA_PATH=C:\Users\<USER>\dev\d2r\d2r-core\d2r-data

# 2. Data Source Paths
# Path to the directory containing D2R JSON data (uniques, sets, properties, etc.)
D2DATA_JSON_DIR=${D2R_SPEC_PATH}\references\d2data\json

# 3. Development Tools
LLVM_LINKER_PATH=C:\Program Files\LLVM\bin\lld-link.exe

# 4. (Optional) Game Save Directory
# D2R_SAVE_DIR=C:\Users\<User>\Saved Games\Diablo II Resurrected
